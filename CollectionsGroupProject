using System;
using System.Collections.Generic;
using System.Linq;

namespace Module7Assignment
{
    class Program
    {
        static void Main(string[] args)
        {
            //Initialize the dictionary with a list of string keys and string values
            Dictionary<string, List<string>> myDictionary = new Dictionary<string, List<string>>();
            bool continueRunning = true;

            while (continueRunning)
            {
                //Displaying the options for the user
                Console.WriteLine("\n--- Dictionary Menu ---");
                Console.WriteLine("1. Populate Dictionary");
                Console.WriteLine("2. Display Dictionary Contents");
                Console.WriteLine("3. Remove a Key");
                Console.WriteLine("4. Add a New Key and Value");
                Console.WriteLine("5. Add a Value to an Existing Key");
                Console.WriteLine("6. Sort the Keys");
                Console.WriteLine("7. Exit");
                Console.WriteLine("Enter your choice (1-7): ");

                string choice = Console.ReadLine();

                //Switch statement to handle menu options
                switch (choice)
                {
                    case "1":
                        // Populate Dictionary
                        myDictionary.Add("Fruits", new List<string> { "Apple", "Banana" });
                        myDictionary.Add("Vehicles", new List<string> { "Car", "Bike" });
                        Console.WriteLine("Dictionary populated with initial data.");
                        break;

                    case "2":
                        // Display dictionary contents using enumeration (foreach KeyValuePair)
                        Console.WriteLine("\nDictionary Contents:");
                        if (myDictionary.Count == 0)
                        {
                            Console.WriteLine("The dictionary is empty.");
                        }
                        else
                        {
                            // KeyValuePair enumeration
                            foreach (KeyValuePair<string, List<string>> kvp in myDictionary)
                            {
                                Console.WriteLine($"Key: {kvp.Key}");
                                foreach (string val in kvp.Value)
                                {
                                    Console.WriteLine($"  - {val}");
                                }
                            }
                        }
                        break;
case "3":
    Console.Write("Enter the key you want to remove: ");
    string removeKey = Console.ReadLine();

    if (myDictionary.Remove(removeKey))
        Console.WriteLine("Key removed.");
    else
        Console.WriteLine("Key not found.");
    break;

case "5":
    Console.Write("Enter existing key: ");
    string existingKey = Console.ReadLine();

    if (myDictionary.ContainsKey(existingKey))
    {
        Console.Write("Enter value to add: ");
        string newValue = Console.ReadLine();
        myDictionary[existingKey].Add(newValue);
        Console.WriteLine("Value added.");
    }
    else
    {
        Console.WriteLine("Key not found.");
    }
    break;
